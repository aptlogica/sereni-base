# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                         SERENIBASE CONFIGURATION                              ║
# ║                                                                                ║
# ║  Copy this file to .env in the root directory and update the values          ║
# ║  Command: cp build/config/.env.example .env                                   ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           🌐 NETWORK CONFIGURATION                            │
# │  Configure how external clients access your application                       │
# └──────────────────────────────────────────────────────────────────────────────┘

# Your server's public IP or domain (used for external access)
# Examples: localhost, 192.168.1.100, myapp.example.com
PUBLIC_HOST=localhost

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           🖥️  SERVER CONFIGURATION                            │
# └──────────────────────────────────────────────────────────────────────────────┘

# Server bind address (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30
SERVER_WRITE_TIMEOUT=30

# Environment: dev, staging, production
SERVER_ENV=dev

# Protocol: http or https
SERVER_SCHEME=http

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           🗄️  DATABASE CONFIGURATION                          │
# └──────────────────────────────────────────────────────────────────────────────┘

# PostgreSQL connection settings
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=serenibase
DATABASE_SSL_MODE=disable

# Connection pool settings
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=1h

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           🔐 AUTHENTICATION SERVICE                           │
# └──────────────────────────────────────────────────────────────────────────────┘

# Internal service URL (Docker network)
AUTH_URL=http://jwt-provider:8081

# Password reset URL - Update PUBLIC_HOST for production
AUTH_RESET_PASSWORD_URL=http://${PUBLIC_HOST}:5050/reset-password?token=%s

# JWT Configuration
AUTH_JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_MIN_32_CHARS
AUTH_PORT=8081
AUTH_HOST=0.0.0.0
AUTH_ALLOWED_ORIGINS=http://${PUBLIC_HOST}:8080,http://${PUBLIC_HOST}:5050,http://serenibase:8080,http://base-ui:5050
AUTH_ENV=development
AUTH_LOG_LEVEL=info

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           👤 OWNER/ADMIN ACCOUNT                              │
# │  First admin user created on initial setup                                    │
# └──────────────────────────────────────────────────────────────────────────────┘

OWNER_FIRST_NAME=Admin
OWNER_LAST_NAME=User
OWNER_EMAIL=admin@example.com
OWNER_PASSWORD=Admin@123

# Temporary password for new users (change in production!)
TEMPORARY_USER_PASSWORD=ChangeMe@123

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           📧 EMAIL SERVICE                                    │
# └──────────────────────────────────────────────────────────────────────────────┘

# Internal service URL
EMAIL_URL=http://email-service:8082/api/v1/email

# Email service settings
EMAIL_HOST=0.0.0.0
EMAIL_PORT=8082
EMAIL_ALLOWED_ORIGIN=http://${PUBLIC_HOST}:8080,http://${PUBLIC_HOST}:5050,http://serenibase:8080,http://base-ui:5050

# SMTP Configuration (Gmail example)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your_email@gmail.com
EMAIL_SMTP_PASSWORD=your_app_password
EMAIL_FROM_EMAIL=your_email@gmail.com

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           📁 STORAGE SERVICE                                  │
# └──────────────────────────────────────────────────────────────────────────────┘

# Internal service URL
STORAGE_URL=http://sereni-storage-provider:8083/api/v1

# Storage service settings
STORAGE_SERVER_PORT=8083
STORAGE_SERVER_HOST=0.0.0.0
STORAGE_SERVER_SCHEME=http
STORAGE_ALLOWED_ORIGINS=http://${PUBLIC_HOST}:8080,http://${PUBLIC_HOST}:5050,http://serenibase:8080,http://base-ui:5050

# Storage driver: local, minio, or aws
STORAGE_DRIVER=local
STORAGE_DEV_PATH=./uploads

# AWS S3 Configuration (if using aws driver)
STORAGE_AWS_REGION=us-east-1
STORAGE_AWS_BUCKET=my-bucket
STORAGE_AWS_ACCESS_KEY=your-access-key
STORAGE_AWS_SECRET_KEY=your-secret-key

# MinIO Configuration (if using minio driver)
STORAGE_MINIO_ENDPOINT=minio:9000
STORAGE_MINIO_ACCESS_KEY=minioadmin
STORAGE_MINIO_SECRET_KEY=minioadmin
STORAGE_MINIO_BUCKET=serenibase
STORAGE_MINIO_USE_SSL=false

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           🦠 ANTIVIRUS SERVICE                                │
# └──────────────────────────────────────────────────────────────────────────────┘

# Internal service URL
ANTIVIRUS_URL=http://antivirus-service:8084

# Antivirus service settings
ANTIVIRUS_HOST=0.0.0.0
ANTIVIRUS_PORT=8084
ANTIVIRUS_BASE_URL=http://antivirus-service:8084
ANTIVIRUS_ALLOWED_ORIGINS=http://${PUBLIC_HOST}:8080,http://${PUBLIC_HOST}:5050,http://serenibase:8080,http://base-ui:5050

# ClamAV Configuration
ANTIVIRUS_DRIVER=clamav
ANTIVIRUS_CLAMAV_ADDRESS=clamav:3310
ANTIVIRUS_CLAMAV_TIMEOUT_SECONDS=30
ANTIVIRUS_MAX_UPLOAD_SIZE_MB=32

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           🎨 FRONTEND (BASE UI)                               │
# └──────────────────────────────────────────────────────────────────────────────┘

# API URL that the frontend will use to connect to backend
# Update PUBLIC_HOST for production deployment
BASEUI_VITE_API_BASE_URL=http://${PUBLIC_HOST}:8080

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           🔒 CORS CONFIGURATION                               │
# │  Controls which domains can access your API                                   │
# └──────────────────────────────────────────────────────────────────────────────┘

# Allowed origins (comma-separated)
# Add your domain/IP for production: http://yourdomain.com,http://192.168.1.100:5050
CORS_ALLOWED_ORIGINS=http://${PUBLIC_HOST}:5050,http://localhost:5050,http://127.0.0.1:5050,http://base-ui:5050
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Content-Length,Accept-Encoding,X-CSRF-Token,Authorization,accept,origin,Cache-Control,X-Requested-With,schema,workspace,base
CORS_ALLOW_CREDENTIALS=true

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           📝 LOGGING CONFIGURATION                            │
# └──────────────────────────────────────────────────────────────────────────────┘

LOG_LEVEL=info
LOG_FILE=app.log
LOG_MAX_SIZE=50
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=30
LOG_COMPRESS=true

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           📦 ASSET CONFIGURATION                              │
# └──────────────────────────────────────────────────────────────────────────────┘

# Max upload size in bytes (default: 5MB)
ASSET_MAX_SIZE=5242880

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                           🔧 DEVELOPMENT ONLY                                 │
# │  ⚠️  DO NOT COMMIT THESE VALUES IN PRODUCTION!                                │
# └──────────────────────────────────────────────────────────────────────────────┘

# GitHub token for cloning private repositories (development only)
GIT_TOKEN=
