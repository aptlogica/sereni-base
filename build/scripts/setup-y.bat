@echo off
REM ========================================================================
REM                    SERENIBASE SETUP SCRIPT (NO PROMPTS)
REM                    Windows Batch Version - Using Defaults
REM ========================================================================
REM
REM Ctrl+C Handling:
REM   Press Ctrl+C to immediately terminate (answers Y automatically)
REM   Or press Y when prompted to terminate
REM
REM ========================================================================

setlocal enabledelayedexpansion

REM Get the directory where this script is located
set "SCRIPT_DIR=%~dp0"
REM Navigate to project root (two levels up from build/scripts/)
cd /d "%SCRIPT_DIR%..\.."

echo.
echo ========================================================================
echo                     SERENIBASE SETUP WIZARD
echo ========================================================================
echo.

REM Check prerequisites
echo Checking prerequisites...
echo.

docker --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] Docker is not installed. Please install Docker Desktop first.
    pause
    exit /b 1
)
echo [OK] Docker is installed

docker compose version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] Docker Compose is not installed.
    pause
    exit /b 1
)
echo [OK] Docker Compose is installed

git --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] Git is not installed. Please install Git first.
    pause
    exit /b 1
)
echo [OK] Git is installed

echo.
echo All prerequisites satisfied!
echo.

REM Setup environment
echo Setting up environment...

REM Create a temporary file with all default environment variables
(
    echo # ╔══════════════════════════════════════════════════════════════════════════════╗
    echo # ║                         SERENIBASE CONFIGURATION                              ║
    echo # ║                  Generated by Interactive Setup Script                        ║
    echo # ╚══════════════════════════════════════════════════════════════════════════════╝
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🌐 NETWORK CONFIGURATION                            │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo PUBLIC_HOST=localhost
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🖥️  SERVER CONFIGURATION                            │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo SERVER_HOST=0.0.0.0
    echo SERVER_PORT=8080
    echo SERVER_READ_TIMEOUT=30
    echo SERVER_WRITE_TIMEOUT=30
    echo SERVER_ENV=dev
    echo SERVER_SCHEME=http
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🗄️  DATABASE CONFIGURATION                          │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo DATABASE_HOST=postgres
    echo DATABASE_PORT=5432
    echo DATABASE_USER=postgres
    echo DATABASE_PASSWORD=postgres
    echo DATABASE_NAME=serenibase
    echo DATABASE_SSL_MODE=disable
    echo DATABASE_MAX_OPEN_CONNS=25
    echo DATABASE_MAX_IDLE_CONNS=5
    echo DATABASE_CONN_MAX_LIFETIME=1h
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🔐 AUTHENTICATION CONFIGURATION                     │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo AUTH_URL=http://jwt-provider:8081
    echo AUTH_RESET_PASSWORD_URL=http://localhost:5050/reset-password?token=%%s
    echo AUTH_JWT_SECRET=change-this-to-a-secure-random-string-min32chars
    echo ACCESS_TOKEN_DURATION=15m
    echo REFRESH_TOKEN_DURATION=168h
    echo AUTH_PORT=8081
    echo AUTH_HOST=0.0.0.0
    echo AUTH_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5050,http://serenibase:8080,http://base-ui:5050
    echo AUTH_ENV=development
    echo AUTH_LOG_LEVEL=info
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           👤 ADMIN ACCOUNT                                    │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo OWNER_FIRST_NAME=Admin
    echo OWNER_LAST_NAME=User
    echo OWNER_EMAIL=admin@example.com
    echo OWNER_PASSWORD=Admin@123
    echo TEMPORARY_USER_PASSWORD=CHANGE_THIS
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           📧 EMAIL CONFIGURATION                              │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo EMAIL_URL=http://email-service:8082/api/v1/email
    echo EMAIL_HOST=0.0.0.0
    echo EMAIL_PORT=8082
    echo EMAIL_ALLOWED_ORIGIN=http://localhost:8080,http://localhost:5050,http://serenibase:8080,http://base-ui:5050
    echo EMAIL_SMTP_HOST=mailhog
    echo EMAIL_SMTP_PORT=1025
    echo EMAIL_SMTP_USERNAME=
    echo EMAIL_SMTP_PASSWORD=
    echo EMAIL_FROM_EMAIL=test@example.com
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           📁 STORAGE CONFIGURATION                            │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo STORAGE_URL=http://sereni-storage-provider:8083/api/v1
    echo STORAGE_SERVER_PORT=8083
    echo STORAGE_SERVER_HOST=0.0.0.0
    echo STORAGE_SERVER_SCHEME=http
    echo STORAGE_DRIVER=rustfs
    echo STORAGE_DEV_PATH=./uploads
    echo STORAGE_AWS_REGION=us-east-1
    echo STORAGE_AWS_BUCKET=serenibase
    echo STORAGE_AWS_ACCESS_KEY=your-access-key
    echo STORAGE_AWS_SECRET_KEY=your-secret-key
    echo RUSTFS_ENDPOINT=http://rustfs-server:9000
    echo RUSTFS_ACCESS_KEY=rustfsadmin
    echo RUSTFS_SECRET_KEY=rustfsadmin
    echo RUSTFS_BUCKET=serenibase
    echo RUSTFS_USE_SSL=false
    echo STORAGE_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5050,http://serenibase:8080,http://base-ui:5050
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🦠 ANTIVIRUS CONFIGURATION                          │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo ANTIVIRUS_URL=http://antivirus-service:8084
    echo ANTIVIRUS_HOST=0.0.0.0
    echo ANTIVIRUS_PORT=8084
    echo ANTIVIRUS_BASE_URL=http://antivirus-service:8084
    echo ANTIVIRUS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5050,http://serenibase:8080,http://base-ui:5050
    echo ANTIVIRUS_DRIVER=clamav
    echo ANTIVIRUS_CLAMAV_ADDRESS=clamav:3310
    echo ANTIVIRUS_CLAMAV_TIMEOUT_SECONDS=30
    echo ANTIVIRUS_MAX_UPLOAD_SIZE_MB=32
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🎨 FRONTEND CONFIGURATION                           │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo BASEUI_VITE_API_BASE_URL=http://localhost:8080
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🔒 CORS CONFIGURATION                               │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo CORS_ALLOWED_ORIGINS=http://localhost:5050,http://127.0.0.1:5050,http://base-ui:5050,http://serenibase:8080
    echo CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
    echo CORS_ALLOWED_HEADERS=Content-Type,Content-Length,Accept-Encoding,X-CSRF-Token,Authorization,accept,origin,Cache-Control,X-Requested-With,schema,workspace,base
    echo CORS_ALLOW_CREDENTIALS=true
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           📝 LOGGING CONFIGURATION                            │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo LOG_LEVEL=info
    echo LOG_FILE=app.log
    echo LOG_MAX_SIZE=50
    echo LOG_MAX_BACKUPS=10
    echo LOG_MAX_AGE=30
    echo LOG_COMPRESS=true
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           📦 ASSET CONFIGURATION                              │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo ASSET_MAX_SIZE=5242880
) > .env.template

if not exist ".env" (
    REM If .env doesn't exist, create it from template
    copy .env.template .env >nul
    echo [OK] Created .env with default environment variables
) else (
    REM If .env exists, append missing variables
    echo [!] .env already exists. Checking for missing variables...
    powershell -NoProfile -ExecutionPolicy Bypass -File "build\scripts\append-env-vars.ps1" -TargetEnv ".env" -TemplateSource ".env.template"
)

REM Clean up template file
del .env.template >nul 2>&1

echo.
echo ========================================================================
echo                      DATABASE CONFIGURATION
echo ========================================================================
echo.
echo Using default PostgreSQL Docker container

REM Check if database credentials already exist, if not update
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -match '(?m)^DATABASE_USER=(.*)$') { $val = $matches[1]; if ($val -eq 'postgres' -or $val -eq '') { (Get-Content '.env') -replace '^DATABASE_USER=.*', 'DATABASE_USER=postgres' | Set-Content '.env' } } else { (Get-Content '.env') -replace '^DATABASE_USER=.*', 'DATABASE_USER=postgres' | Set-Content '.env' }"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -match '(?m)^DATABASE_PASSWORD=(.*)$') { $val = $matches[1]; if ($val -eq 'postgres' -or $val -eq '') { (Get-Content '.env') -replace '^DATABASE_PASSWORD=.*', 'DATABASE_PASSWORD=postgres' | Set-Content '.env' } } else { (Get-Content '.env') -replace '^DATABASE_PASSWORD=.*', 'DATABASE_PASSWORD=postgres' | Set-Content '.env' }"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -match '(?m)^DATABASE_NAME=(.*)$') { $val = $matches[1]; if ($val -eq 'serenibase' -or $val -eq '') { (Get-Content '.env') -replace '^DATABASE_NAME=.*', 'DATABASE_NAME=serenibase' | Set-Content '.env' } } else { (Get-Content '.env') -replace '^DATABASE_NAME=.*', 'DATABASE_NAME=serenibase' | Set-Content '.env' }"

echo [OK] Database configuration set to defaults

echo.
echo ========================================================================
echo                      AUTHENTICATION CONFIGURATION
echo ========================================================================
echo.

REM Check if JWT secret exists and is not default, if default then generate new one
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -match '(?m)^AUTH_JWT_SECRET=(.*)$') { $val = $matches[1]; if ($val -match 'change-this' -or $val -eq '') { $newSecret = [System.Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Guid).ToString() + (New-Guid).ToString())).Substring(0,32); (Get-Content '.env') -replace '^AUTH_JWT_SECRET=.*', \"AUTH_JWT_SECRET=$newSecret\" | Set-Content '.env'; Write-Host \"[OK] Generated new JWT Secret: $newSecret\" } else { Write-Host \"[OK] Using existing JWT Secret\" } } else { $newSecret = [System.Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Guid).ToString() + (New-Guid).ToString())).Substring(0,32); (Get-Content '.env') -replace '^AUTH_JWT_SECRET=.*', \"AUTH_JWT_SECRET=$newSecret\" | Set-Content '.env'; Write-Host \"[OK] Generated new JWT Secret: $newSecret\" }"

echo.
echo ========================================================================
echo                      EMAIL CONFIGURATION
echo ========================================================================
echo.

REM Check if email is configured, if not set defaults
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -match '(?m)^EMAIL_SMTP_USERNAME=(.*)$') { $val = $matches[1]; if ($val -notmatch '@' -or $val -eq 'your_email@gmail.com') { echo '[WARNING] Email not configured. Please update .env with your email credentials.' } else { echo '[OK] Using existing email configuration' } } else { echo '[WARNING] Email not configured. Please update .env with your email credentials.' }"

echo.
echo ========================================================================
echo                      STORAGE CONFIGURATION
echo ========================================================================
echo.

echo Using default RustFS Docker container

REM Set default RustFS storage if not already configured
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -match '(?m)^STORAGE_DRIVER=(.*)$') { $val = $matches[1]; if ($val -eq '' -or $val -eq 'rustfs') { (Get-Content '.env') -replace '^STORAGE_DRIVER=.*', 'STORAGE_DRIVER=rustfs' | Set-Content '.env' } } else { (Get-Content '.env') -replace '^STORAGE_DRIVER=.*', 'STORAGE_DRIVER=rustfs' | Set-Content '.env' }"
powershell -Command "(Get-Content '.env') -replace '^RUSTFS_ENDPOINT=.*', 'RUSTFS_ENDPOINT=http://rustfs-server:9000' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^RUSTFS_ACCESS_KEY=.*', 'RUSTFS_ACCESS_KEY=rustfsadmin' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^RUSTFS_SECRET_KEY=.*', 'RUSTFS_SECRET_KEY=rustfsadmin' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^RUSTFS_BUCKET=.*', 'RUSTFS_BUCKET=serenibase' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^RUSTFS_USE_SSL=.*', 'RUSTFS_USE_SSL=false' | Set-Content '.env'"

echo [OK] Storage configuration set to defaults

echo.
echo ========================================================================
echo                      NETWORK CONFIGURATION
echo ========================================================================
echo.
set PUBLIC_HOST=localhost
echo Using default IP/domain: %PUBLIC_HOST%

REM Update .env file with PUBLIC_HOST, BASEUI_VITE_API_BASE_URL and STORAGE_SERVER_IP
REM Only add if the key doesn't exist already
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^PUBLIC_HOST=') { $content += \"`nPUBLIC_HOST=%PUBLIC_HOST%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^SERVER_IP=') { $content += \"`nSERVER_IP=%PUBLIC_HOST%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^BASEUI_VITE_API_BASE_URL=') { $content += \"`nBASEUI_VITE_API_BASE_URL=http://%PUBLIC_HOST%:8080\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^CORS_ALLOWED_ORIGINS=') { $content += \"`nCORS_ALLOWED_ORIGINS=http://localhost:5050,http://127.0.0.1:5050,http://%PUBLIC_HOST%:5050,http://base-ui:5050,http://serenibase:8080\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^STORAGE_SERVER_IP=') { $content += \"`nSTORAGE_SERVER_IP=%PUBLIC_HOST%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^AUTH_RESET_PASSWORD_URL=') { $content += \"`nAUTH_RESET_PASSWORD_URL=http://%PUBLIC_HOST%:5050/reset-password?token=%%s\" }; Set-Content '.env' -Value $content -NoNewline"
echo [OK] Configured PUBLIC_HOST (added if missing)
echo [OK] Configured SERVER_IP (added if missing)
echo [OK] Configured BASEUI_VITE_API_BASE_URL (added if missing)
echo [OK] Configured AUTH_RESET_PASSWORD_URL (added if missing)

echo.
echo ========================================================================
echo                   OWNER REGISTRATION CONFIGURATION
echo ========================================================================
echo.
echo Using default values:
echo.

set OWNER_FIRST_NAME=Admin
set OWNER_LAST_NAME=User
set OWNER_EMAIL=admin@example.com
set OWNER_PASSWORD=Admin@123

echo   First Name: %OWNER_FIRST_NAME%
echo   Last Name:  %OWNER_LAST_NAME%
echo   Email:      %OWNER_EMAIL%
echo   Password:   %OWNER_PASSWORD%
echo.

REM Update .env file with owner configuration (add only if not already present)
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^OWNER_FIRST_NAME=') { $content += \"`nOWNER_FIRST_NAME=%OWNER_FIRST_NAME%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^OWNER_LAST_NAME=') { $content += \"`nOWNER_LAST_NAME=%OWNER_LAST_NAME%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^OWNER_EMAIL=') { $content += \"`nOWNER_EMAIL=%OWNER_EMAIL%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^OWNER_PASSWORD=') { $content += \"`nOWNER_PASSWORD=%OWNER_PASSWORD%\" }; Set-Content '.env' -Value $content -NoNewline"

echo [OK] Owner configuration set (only added if missing)
echo ========================================================================
echo                      CLONING REPOSITORIES
echo ========================================================================
echo.

REM Clone services using PowerShell scripts
if exist "build\scripts\clone-services.ps1" (
    echo Cloning microservices...
    powershell -NoProfile -ExecutionPolicy Bypass -File build\scripts\clone-services.ps1
    echo [OK] Cloned microservices
)

if exist "build\scripts\clone-go-postgres-rest.ps1" (
    echo Cloning go-postgres-rest...
    powershell -NoProfile -ExecutionPolicy Bypass -File build\scripts\clone-go-postgres-rest.ps1
    echo [OK] Cloned go-postgres-rest
)

echo.
echo ========================================================================
echo                      STARTING SERVICES
echo ========================================================================
echo.

docker compose -f docker-compose.all.yaml up --build -d

echo.
echo Waiting for services to start...
timeout /t 10 /nobreak >nul

docker compose -f docker-compose.all.yaml ps

echo.
echo ========================================================================
echo                      SETUP COMPLETE!
echo ========================================================================
echo.
echo Access your application at:
echo   Frontend:  http://%PUBLIC_HOST%:5050
echo   Backend:   http://%PUBLIC_HOST%:8080
echo   RustFS:     http://%PUBLIC_HOST%:9001
echo.
echo Default admin credentials:
echo   Email:    %OWNER_EMAIL%
echo   Password: %OWNER_PASSWORD%
echo.
echo NOTE: Timezone is set to UTC. You can change it from Profile settings.
echo.
echo WARNING: Remember to change default passwords in production!
echo.
echo Useful commands:
echo   make logs      - View service logs
echo   make down-all  - Stop all services
echo   make clean     - Remove all data
echo.
pause

