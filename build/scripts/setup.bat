@echo off
REM ========================================================================
REM                    SERENIBASE SETUP SCRIPT
REM                    Windows Batch Version
REM ========================================================================
REM
REM Ctrl+C Handling:
REM   Press Ctrl+C to immediately terminate (answers Y automatically)
REM   Or press Y when prompted to terminate
REM
REM ========================================================================

setlocal enabledelayedexpansion

REM Get the directory where this script is located
set "SCRIPT_DIR=%~dp0"
REM Navigate to project root (two levels up from build/scripts/)
cd /d "%SCRIPT_DIR%..\.."

echo.
echo ========================================================================
echo                     SERENIBASE SETUP WIZARD
echo ========================================================================
echo.

REM Check prerequisites
echo Checking prerequisites...
echo.

docker --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] Docker is not installed. Please install Docker Desktop first.
    pause
    exit /b 1
)
echo [OK] Docker is installed

docker compose version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] Docker Compose is not installed.
    pause
    exit /b 1
)
echo [OK] Docker Compose is installed

git --version >nul 2>&1
if %errorlevel% neq 0 (
    echo [X] Git is not installed. Please install Git first.
    pause
    exit /b 1
)
echo [OK] Git is installed

echo.
echo All prerequisites satisfied!
echo.

REM Setup environment
echo Setting up environment...

REM Create a temporary file with all default environment variables
(
    echo # ╔══════════════════════════════════════════════════════════════════════════════╗
    echo # ║                         SERENIBASE CONFIGURATION                              ║
    echo # ║                  Generated by Interactive Setup Script                        ║
    echo # ╚══════════════════════════════════════════════════════════════════════════════╝
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🌐 NETWORK CONFIGURATION                            │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo PUBLIC_HOST=localhost
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🖥️  SERVER CONFIGURATION                            │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo SERVER_HOST=0.0.0.0
    echo SERVER_PORT=8080
    echo SERVER_READ_TIMEOUT=30
    echo SERVER_WRITE_TIMEOUT=30
    echo SERVER_ENV=dev
    echo SERVER_SCHEME=http
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🗄️  DATABASE CONFIGURATION                          │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo DATABASE_HOST=postgres
    echo DATABASE_PORT=5432
    echo DATABASE_USER=postgres
    echo DATABASE_PASSWORD=postgres
    echo DATABASE_NAME=serenibase
    echo DATABASE_SSL_MODE=disable
    echo DATABASE_MAX_OPEN_CONNS=25
    echo DATABASE_MAX_IDLE_CONNS=5
    echo DATABASE_CONN_MAX_LIFETIME=1h
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🔐 AUTHENTICATION CONFIGURATION                     │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo AUTH_URL=http://jwt-provider:8081
    echo AUTH_RESET_PASSWORD_URL=http://localhost:5050/reset-password?token=%%s
    echo AUTH_JWT_SECRET=change-this-to-a-secure-random-string-min32chars
    echo AUTH_PORT=8081
    echo AUTH_HOST=0.0.0.0
    echo AUTH_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5050,http://serenibase:8080,http://base-ui:5050
    echo AUTH_ENV=development
    echo AUTH_LOG_LEVEL=info
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           👤 ADMIN ACCOUNT                                    │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo OWNER_FIRST_NAME=Admin
    echo OWNER_LAST_NAME=User
    echo OWNER_EMAIL=admin@example.com
    echo OWNER_PASSWORD=Admin@123
    echo TEMPORARY_USER_PASSWORD=FC4i;^<S8q?~0
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           📧 EMAIL CONFIGURATION                              │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo EMAIL_URL=http://email-service:8082/api/v1/email
    echo EMAIL_HOST=0.0.0.0
    echo EMAIL_PORT=8082
    echo EMAIL_ALLOWED_ORIGIN=http://localhost:8080,http://localhost:5050,http://serenibase:8080,http://base-ui:5050
    echo EMAIL_SMTP_HOST=mailhog
    echo EMAIL_SMTP_PORT=1025
    echo EMAIL_SMTP_USERNAME=
    echo EMAIL_SMTP_PASSWORD=
    echo EMAIL_FROM_EMAIL=test@example.com
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           📁 STORAGE CONFIGURATION                            │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo STORAGE_URL=http://sereni-storage-provider:8083/api/v1
    echo STORAGE_SERVER_PORT=8083
    echo STORAGE_SERVER_HOST=0.0.0.0
    echo STORAGE_SERVER_SCHEME=http
    echo STORAGE_DRIVER=minio
    echo STORAGE_DEV_PATH=./uploads
    echo STORAGE_AWS_REGION=us-east-1
    echo STORAGE_AWS_BUCKET=serenibase
    echo STORAGE_AWS_ACCESS_KEY=your-access-key
    echo STORAGE_AWS_SECRET_KEY=your-secret-key
    echo STORAGE_MINIO_ENDPOINT=minio:9000
    echo STORAGE_MINIO_ACCESS_KEY=minioadmin
    echo STORAGE_MINIO_SECRET_KEY=minioadmin
    echo STORAGE_MINIO_BUCKET=serenibase
    echo STORAGE_MINIO_USE_SSL=false
    echo STORAGE_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5050,http://serenibase:8080,http://base-ui:5050
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🦠 ANTIVIRUS CONFIGURATION                          │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo ANTIVIRUS_URL=http://antivirus-service:8084
    echo ANTIVIRUS_HOST=0.0.0.0
    echo ANTIVIRUS_PORT=8084
    echo ANTIVIRUS_BASE_URL=http://antivirus-service:8084
    echo ANTIVIRUS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5050,http://serenibase:8080,http://base-ui:5050
    echo ANTIVIRUS_DRIVER=clamav
    echo ANTIVIRUS_CLAMAV_ADDRESS=clamav:3310
    echo ANTIVIRUS_CLAMAV_TIMEOUT_SECONDS=30
    echo ANTIVIRUS_MAX_UPLOAD_SIZE_MB=32
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🎨 FRONTEND CONFIGURATION                           │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo BASEUI_VITE_API_BASE_URL=http://localhost:8080
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           🔒 CORS CONFIGURATION                               │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo CORS_ALLOWED_ORIGINS=http://localhost:5050,http://127.0.0.1:5050,http://base-ui:5050,http://serenibase:8080
    echo CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
    echo CORS_ALLOWED_HEADERS=Content-Type,Content-Length,Accept-Encoding,X-CSRF-Token,Authorization,accept,origin,Cache-Control,X-Requested-With,schema,workspace,base
    echo CORS_ALLOW_CREDENTIALS=true
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           📝 LOGGING CONFIGURATION                            │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo LOG_LEVEL=info
    echo LOG_FILE=app.log
    echo LOG_MAX_SIZE=50
    echo LOG_MAX_BACKUPS=10
    echo LOG_MAX_AGE=30
    echo LOG_COMPRESS=true
    echo.
    echo # ┌──────────────────────────────────────────────────────────────────────────────┐
    echo # │                           📦 ASSET CONFIGURATION                              │
    echo # └──────────────────────────────────────────────────────────────────────────────┘
    echo.
    echo ASSET_MAX_SIZE=5242880
) > .env.template

if not exist ".env" (
    REM If .env doesn't exist, create it from template
    copy .env.template .env >nul
    echo [OK] Created .env with default environment variables
) else (
    REM If .env exists, append missing variables
    echo [!] .env already exists. Checking for missing variables...
    powershell -NoProfile -ExecutionPolicy Bypass -File "build\scripts\append-env-vars.ps1" -TargetEnv ".env" -TemplateSource ".env.template"
)

REM Clean up template file
del .env.template >nul 2>&1

echo.
echo ========================================================================
echo                      DATABASE CONFIGURATION
echo ========================================================================
echo.
echo Choose database setup:
echo   1. Use default PostgreSQL (Docker container)
echo   2. Use custom database credentials
echo.
set /p DB_CHOICE="Enter choice [1]: "
if "%DB_CHOICE%"=="" set DB_CHOICE=1

if "%DB_CHOICE%"=="1" (
    echo.
    echo Using default PostgreSQL Docker container
    echo.
    set /p DATABASE_USER="Database User [postgres]: "
    if "!DATABASE_USER!"=="" set DATABASE_USER=postgres
    
    set /p DATABASE_PASSWORD="Database Password [postgres]: "
    if "!DATABASE_PASSWORD!"=="" set DATABASE_PASSWORD=postgres
    
    set /p DATABASE_NAME="Database Name [serenibase]: "
    if "!DATABASE_NAME!"=="" set DATABASE_NAME=serenibase
    
    set DATABASE_HOST=postgres
    set DATABASE_PORT=5432
    set DATABASE_SSL_MODE=disable
) else (
    echo.
    echo Enter custom database configuration:
    echo.
    set /p DATABASE_HOST="Database Host: "
    if "!DATABASE_HOST!"=="" (
        echo [ERROR] Database host is required
        pause
        exit /b 1
    )
    
    set /p DATABASE_PORT="Database Port [5432]: "
    if "!DATABASE_PORT!"=="" set DATABASE_PORT=5432
    
    set /p DATABASE_USER="Database User: "
    if "!DATABASE_USER!"=="" (
        echo [ERROR] Database user is required
        pause
        exit /b 1
    )
    
    set /p DATABASE_PASSWORD="Database Password: "
    if "!DATABASE_PASSWORD!"=="" (
        echo [ERROR] Database password is required
        pause
        exit /b 1
    )
    
    set /p DATABASE_NAME="Database Name: "
    if "!DATABASE_NAME!"=="" (
        echo [ERROR] Database name is required
        pause
        exit /b 1
    )
    
    set /p DATABASE_SSL_MODE="SSL Mode [disable]: "
    if "!DATABASE_SSL_MODE!"=="" set DATABASE_SSL_MODE=disable
)

REM Update database configuration in .env
powershell -Command "(Get-Content '.env') -replace '^DATABASE_HOST=.*', 'DATABASE_HOST=%DATABASE_HOST%' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^DATABASE_PORT=.*', 'DATABASE_PORT=%DATABASE_PORT%' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^DATABASE_USER=.*', 'DATABASE_USER=%DATABASE_USER%' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^DATABASE_PASSWORD=.*', 'DATABASE_PASSWORD=%DATABASE_PASSWORD%' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^DATABASE_NAME=.*', 'DATABASE_NAME=%DATABASE_NAME%' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^DATABASE_SSL_MODE=.*', 'DATABASE_SSL_MODE=%DATABASE_SSL_MODE%' | Set-Content '.env'"

echo [OK] Database configuration updated

echo.
echo ========================================================================
echo                      AUTHENTICATION CONFIGURATION
echo ========================================================================
echo.
set /p AUTH_JWT_SECRET="JWT Secret (min 32 chars) [press Enter to generate]: "
if "!AUTH_JWT_SECRET!"=="" (
    REM Generate random JWT secret
    for /f %%i in ('powershell -Command "[System.Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((New-Guid).ToString() + (New-Guid).ToString())).Substring(0,32)"') do set AUTH_JWT_SECRET=%%i
    echo Generated JWT Secret: !AUTH_JWT_SECRET!
)

REM Update JWT secret in .env
powershell -Command "(Get-Content '.env') -replace '^AUTH_JWT_SECRET=.*', 'AUTH_JWT_SECRET=%AUTH_JWT_SECRET%' | Set-Content '.env'"
echo [OK] JWT Secret configured

echo.
echo ========================================================================
echo                      EMAIL CONFIGURATION
echo ========================================================================
echo.
echo Choose email configuration:
echo   1. MailHog (Local testing - recommended for development)
echo   2. Custom SMTP (Gmail, SendGrid, etc.)
echo.

set /p EMAIL_CHOICE="Enter choice [1]: "
if "!EMAIL_CHOICE!"=="" set EMAIL_CHOICE=1

if "!EMAIL_CHOICE!"=="1" (
    echo [OK] Configuring MailHog for email testing...
    set EMAIL_SMTP_HOST=mailhog
    set EMAIL_SMTP_PORT=1025
    set EMAIL_SMTP_USERNAME=
    set EMAIL_SMTP_PASSWORD=
    set EMAIL_FROM_EMAIL=test@example.com
    echo.
    echo [OK] MailHog configured successfully!
    echo   - SMTP Server: mailhog:1025
    echo   - Web UI: http://localhost:8025
    echo   - All emails will be caught by MailHog (no real emails sent^)
    echo.
    goto UPDATE_EMAIL_ENV
)

echo.
echo Enter SMTP email configuration:
echo.

set /p EMAIL_SMTP_HOST="SMTP Host [smtp.gmail.com]: "
if "!EMAIL_SMTP_HOST!"=="" set EMAIL_SMTP_HOST=smtp.gmail.com

set /p EMAIL_SMTP_PORT="SMTP Port [587]: "
if "!EMAIL_SMTP_PORT!"=="" set EMAIL_SMTP_PORT=587

set /p EMAIL_SMTP_USERNAME="SMTP Username (email): "
if "!EMAIL_SMTP_USERNAME!"=="" (
    echo [WARNING] Email username not provided. Switching to MailHog for testing.
    set EMAIL_SMTP_HOST=mailhog
    set EMAIL_SMTP_PORT=1025
    set EMAIL_SMTP_USERNAME=
    set EMAIL_SMTP_PASSWORD=
    set EMAIL_FROM_EMAIL=test@example.com
    goto UPDATE_EMAIL_ENV
)

set /p EMAIL_SMTP_PASSWORD="SMTP Password (app password): "
if "!EMAIL_SMTP_PASSWORD!"=="" (
    echo [WARNING] Email password not provided. Email features will not work.
    set EMAIL_SMTP_PASSWORD=your_app_password
)

set /p EMAIL_FROM_EMAIL="From Email [!EMAIL_SMTP_USERNAME!]: "
if "!EMAIL_FROM_EMAIL!"=="" set EMAIL_FROM_EMAIL=!EMAIL_SMTP_USERNAME!

:UPDATE_EMAIL_ENV
REM Update email configuration in .env
powershell -Command "(Get-Content '.env') -replace '^EMAIL_SMTP_HOST=.*', 'EMAIL_SMTP_HOST=%EMAIL_SMTP_HOST%' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^EMAIL_SMTP_PORT=.*', 'EMAIL_SMTP_PORT=%EMAIL_SMTP_PORT%' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^EMAIL_SMTP_USERNAME=.*', 'EMAIL_SMTP_USERNAME=%EMAIL_SMTP_USERNAME%' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^EMAIL_SMTP_PASSWORD=.*', 'EMAIL_SMTP_PASSWORD=%EMAIL_SMTP_PASSWORD%' | Set-Content '.env'"
powershell -Command "(Get-Content '.env') -replace '^EMAIL_FROM_EMAIL=.*', 'EMAIL_FROM_EMAIL=%EMAIL_FROM_EMAIL%' | Set-Content '.env'"

echo [OK] Email configuration updated

echo.
echo ========================================================================
echo                      STORAGE CONFIGURATION
echo ========================================================================
echo.
echo Choose storage driver:
echo   1. Local filesystem (for development only)
echo   2. MinIO (Docker container - recommended)
echo   3. MinIO Custom (external MinIO server)
echo   4. AWS S3
echo.
set /p STORAGE_CHOICE="Enter choice [2]: "
if "!STORAGE_CHOICE!"=="" set STORAGE_CHOICE=2

if "!STORAGE_CHOICE!"=="1" (
    echo.
    echo Using local filesystem storage
    set STORAGE_DRIVER=local
    set /p STORAGE_DEV_PATH="Storage path [./uploads]: "
    if "!STORAGE_DEV_PATH!"=="" set STORAGE_DEV_PATH=./uploads
    
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_DRIVER=.*', 'STORAGE_DRIVER=local' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_DEV_PATH=.*', 'STORAGE_DEV_PATH=%STORAGE_DEV_PATH%' | Set-Content '.env'"
    echo [OK] Local filesystem storage configured
    
) else if "!STORAGE_CHOICE!"=="2" (
    echo.
    echo Using default MinIO Docker container
    set STORAGE_DRIVER=minio
    
    set /p STORAGE_MINIO_ACCESS_KEY="MinIO Access Key [minioadmin]: "
    if "!STORAGE_MINIO_ACCESS_KEY!"=="" set STORAGE_MINIO_ACCESS_KEY=minioadmin
    
    set /p STORAGE_MINIO_SECRET_KEY="MinIO Secret Key [minioadmin]: "
    if "!STORAGE_MINIO_SECRET_KEY!"=="" set STORAGE_MINIO_SECRET_KEY=minioadmin
    
    set /p STORAGE_MINIO_BUCKET="Bucket Name [serenibase]: "
    if "!STORAGE_MINIO_BUCKET!"=="" set STORAGE_MINIO_BUCKET=serenibase
    
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_DRIVER=.*', 'STORAGE_DRIVER=minio' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_MINIO_ENDPOINT=.*', 'STORAGE_MINIO_ENDPOINT=minio:9000' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_MINIO_ACCESS_KEY=.*', 'STORAGE_MINIO_ACCESS_KEY=%STORAGE_MINIO_ACCESS_KEY%' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_MINIO_SECRET_KEY=.*', 'STORAGE_MINIO_SECRET_KEY=%STORAGE_MINIO_SECRET_KEY%' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_MINIO_BUCKET=.*', 'STORAGE_MINIO_BUCKET=%STORAGE_MINIO_BUCKET%' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_MINIO_USE_SSL=.*', 'STORAGE_MINIO_USE_SSL=false' | Set-Content '.env'"
    echo [OK] MinIO Docker storage configured
    
) else if "!STORAGE_CHOICE!"=="3" (
    echo.
    echo Enter custom MinIO configuration:
    echo.
    
    set /p STORAGE_MINIO_ENDPOINT="MinIO Endpoint (host:port): "
    if "!STORAGE_MINIO_ENDPOINT!"=="" (
        echo [ERROR] MinIO endpoint is required
        pause
        exit /b 1
    )
    
    set /p STORAGE_MINIO_ACCESS_KEY="MinIO Access Key: "
    if "!STORAGE_MINIO_ACCESS_KEY!"=="" (
        echo [ERROR] MinIO access key is required
        pause
        exit /b 1
    )
    
    set /p STORAGE_MINIO_SECRET_KEY="MinIO Secret Key: "
    if "!STORAGE_MINIO_SECRET_KEY!"=="" (
        echo [ERROR] MinIO secret key is required
        pause
        exit /b 1
    )
    
    set /p STORAGE_MINIO_BUCKET="Bucket Name [serenibase]: "
    if "!STORAGE_MINIO_BUCKET!"=="" set STORAGE_MINIO_BUCKET=serenibase
    
    set /p STORAGE_MINIO_USE_SSL="Use SSL (true/false) [false]: "
    if "!STORAGE_MINIO_USE_SSL!"=="" set STORAGE_MINIO_USE_SSL=false
    
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_DRIVER=.*', 'STORAGE_DRIVER=minio' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_MINIO_ENDPOINT=.*', 'STORAGE_MINIO_ENDPOINT=%STORAGE_MINIO_ENDPOINT%' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_MINIO_ACCESS_KEY=.*', 'STORAGE_MINIO_ACCESS_KEY=%STORAGE_MINIO_ACCESS_KEY%' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_MINIO_SECRET_KEY=.*', 'STORAGE_MINIO_SECRET_KEY=%STORAGE_MINIO_SECRET_KEY%' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_MINIO_BUCKET=.*', 'STORAGE_MINIO_BUCKET=%STORAGE_MINIO_BUCKET%' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_MINIO_USE_SSL=.*', 'STORAGE_MINIO_USE_SSL=%STORAGE_MINIO_USE_SSL%' | Set-Content '.env'"
    echo [OK] Custom MinIO storage configured
    
) else if "!STORAGE_CHOICE!"=="4" (
    echo.
    echo Enter AWS S3 configuration:
    echo.
    
    set /p STORAGE_AWS_REGION="AWS Region [us-east-1]: "
    if "!STORAGE_AWS_REGION!"=="" set STORAGE_AWS_REGION=us-east-1
    
    set /p STORAGE_AWS_BUCKET="S3 Bucket Name: "
    if "!STORAGE_AWS_BUCKET!"=="" (
        echo [ERROR] S3 bucket name is required
        pause
        exit /b 1
    )
    
    set /p STORAGE_AWS_ACCESS_KEY="AWS Access Key: "
    if "!STORAGE_AWS_ACCESS_KEY!"=="" (
        echo [ERROR] AWS access key is required
        pause
        exit /b 1
    )
    
    set /p STORAGE_AWS_SECRET_KEY="AWS Secret Key: "
    if "!STORAGE_AWS_SECRET_KEY!"=="" (
        echo [ERROR] AWS secret key is required
        pause
        exit /b 1
    )
    
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_DRIVER=.*', 'STORAGE_DRIVER=s3' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_AWS_REGION=.*', 'STORAGE_AWS_REGION=%STORAGE_AWS_REGION%' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_AWS_BUCKET=.*', 'STORAGE_AWS_BUCKET=%STORAGE_AWS_BUCKET%' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_AWS_ACCESS_KEY=.*', 'STORAGE_AWS_ACCESS_KEY=%STORAGE_AWS_ACCESS_KEY%' | Set-Content '.env'"
    powershell -Command "(Get-Content '.env') -replace '^STORAGE_AWS_SECRET_KEY=.*', 'STORAGE_AWS_SECRET_KEY=%STORAGE_AWS_SECRET_KEY%' | Set-Content '.env'"
    echo [OK] AWS S3 storage configured
    
) else (
    echo [ERROR] Invalid choice
    pause
    exit /b 1
)

echo.
echo ========================================================================
echo                      NETWORK CONFIGURATION
echo ========================================================================
echo.
set /p PUBLIC_HOST="Enter IP/domain [localhost]: "
if "%PUBLIC_HOST%"=="" set PUBLIC_HOST=localhost

REM Update .env file with PUBLIC_HOST, BASEUI_VITE_API_BASE_URL and STORAGE_SERVER_IP
REM Only add if the key doesn't exist already
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^PUBLIC_HOST=') { $content += \"`nPUBLIC_HOST=%PUBLIC_HOST%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^SERVER_IP=') { $content += \"`nSERVER_IP=%PUBLIC_HOST%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^BASEUI_VITE_API_BASE_URL=') { $content += \"`nBASEUI_VITE_API_BASE_URL=http://%PUBLIC_HOST%:8080\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^CORS_ALLOWED_ORIGINS=') { $content += \"`nCORS_ALLOWED_ORIGINS=http://localhost:5050,http://127.0.0.1:5050,http://%PUBLIC_HOST%:5050,http://base-ui:5050,http://serenibase:8080\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^STORAGE_SERVER_IP=') { $content += \"`nSTORAGE_SERVER_IP=%PUBLIC_HOST%\" }; Set-Content '.env' -Value $content -NoNewline"
echo [OK] Configured PUBLIC_HOST (added if missing)
echo [OK] Configured SERVER_IP (added if missing)
echo [OK] Configured BASEUI_VITE_API_BASE_URL (added if missing)

echo.
echo ========================================================================
echo                   OWNER REGISTRATION CONFIGURATION
echo ========================================================================
echo.
echo Enter owner registration details (press Enter to use defaults):
echo.

set /p OWNER_FIRST_NAME="First Name [Admin]: "
if "%OWNER_FIRST_NAME%"=="" set OWNER_FIRST_NAME=Admin

set /p OWNER_LAST_NAME="Last Name [User]: "
if "%OWNER_LAST_NAME%"=="" set OWNER_LAST_NAME=User

set /p OWNER_EMAIL="Email [admin@example.com]: "
if "%OWNER_EMAIL%"=="" set OWNER_EMAIL=admin@example.com

set /p OWNER_PASSWORD="Password [Admin@123]: "
if "%OWNER_PASSWORD%"=="" set OWNER_PASSWORD=Admin@123

REM Update .env file with owner configuration (add only if not already present)
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^OWNER_FIRST_NAME=') { $content += \"`nOWNER_FIRST_NAME=%OWNER_FIRST_NAME%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^OWNER_LAST_NAME=') { $content += \"`nOWNER_LAST_NAME=%OWNER_LAST_NAME%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^OWNER_EMAIL=') { $content += \"`nOWNER_EMAIL=%OWNER_EMAIL%\" }; Set-Content '.env' -Value $content -NoNewline"
powershell -Command "$content = Get-Content '.env' -Raw; if ($content -notmatch '(?m)^OWNER_PASSWORD=') { $content += \"`nOWNER_PASSWORD=%OWNER_PASSWORD%\" }; Set-Content '.env' -Value $content -NoNewline"

echo [OK] Owner configuration set (only added if missing)
echo ========================================================================
echo                      CLONING REPOSITORIES
echo ========================================================================
echo.

REM Clone services using PowerShell scripts
if exist "build\scripts\clone-services.ps1" (
    echo Cloning microservices...
    powershell -NoProfile -ExecutionPolicy Bypass -File build\scripts\clone-services.ps1
    echo [OK] Cloned microservices
)

if exist "build\scripts\clone-go-postgres-rest.ps1" (
    echo Cloning go-postgres-rest...
    powershell -NoProfile -ExecutionPolicy Bypass -File build\scripts\clone-go-postgres-rest.ps1
    echo [OK] Cloned go-postgres-rest
)

echo.
echo ========================================================================
echo                      STARTING SERVICES
echo ========================================================================
echo.

docker compose -f docker-compose.all.yaml up --build -d

echo.
echo Waiting for services to start...
timeout /t 10 /nobreak >nul

docker compose -f docker-compose.all.yaml ps

echo.
echo ========================================================================
echo                      SETUP COMPLETE!
echo ========================================================================
echo.
echo Access your application at:
echo   Frontend:  http://%PUBLIC_HOST%:5050
echo   Backend:   http://%PUBLIC_HOST%:8080
echo   MinIO:     http://%PUBLIC_HOST%:9001
echo.
echo Default admin credentials:
echo   Email:    %OWNER_EMAIL%
echo   Password: %OWNER_PASSWORD%
echo.
echo WARNING: Remember to change default passwords in production!
echo.
echo Useful commands:
echo   make logs      - View service logs
echo   make down-all  - Stop all services
echo   make clean     - Remove all data
echo.
pause
